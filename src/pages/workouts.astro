---
import Layout from "@/layouts/Layout.astro";
import WorkoutLogForm from "@/components/workouts/WorkoutLogForm";
import RecentWorkouts from "@/components/workouts/RecentWorkouts.astro";
import PlannedWorkouts from "@/components/workouts/PlannedWorkouts.astro";
import { createClient } from "@/lib/supabase";
import { getMuscleGroups, getExercises } from "@/lib/catalog";
import { getRecentWorkouts, getPlannedWorkouts } from "@/lib/workouts";
import { generateProposal } from "@/lib/proposal";

const error = Astro.url.searchParams.get("error");
const saved = Astro.url.searchParams.get("saved") === "1";
const planned = Astro.url.searchParams.get("planned") === "1";

const proposeRequested = Astro.url.searchParams.has("propose");
const proposeMuscleGroup = Astro.url.searchParams.get("muscleGroup") ?? "";
const proposeDate = Astro.url.searchParams.get("date") ?? "";

const supabase = createClient(Astro.request.headers, Astro.cookies);
const muscleGroups = await getMuscleGroups(supabase);
const exercises = await getExercises(supabase);

const { user } = Astro.locals;
const recentWorkouts = user ? await getRecentWorkouts(supabase, user.id, 10, "logged") : [];
const plannedWorkouts = user ? await getPlannedWorkouts(supabase, user.id) : [];

const proposal = proposeRequested && user ? await generateProposal(supabase, user.id, proposeMuscleGroup) : null;
---

<Layout title="Log a workout">
  <div class="bg-cosmic flex min-h-screen items-start justify-center p-4 py-10">
    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Log a workout
      </h1>
      <WorkoutLogForm
        muscleGroups={muscleGroups}
        exercises={exercises}
        serverError={error}
        saved={saved}
        planned={planned}
        proposal={proposal}
        proposeMuscleGroup={proposeMuscleGroup}
        proposeDate={proposeDate}
        client:load
      />
      <PlannedWorkouts workouts={plannedWorkouts} />
      <RecentWorkouts workouts={recentWorkouts} />
      <p class="mt-4 text-center text-sm text-blue-100/60">
        <a href="/dashboard" class="text-purple-300 hover:underline">Back to dashboard</a>
      </p>
    </div>
  </div>
</Layout>
